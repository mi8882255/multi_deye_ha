{
  "name": "deye-multi-inverter-reader",
  "version": "1.0.0",
  "description": "Multi-inverter Deye reader via Modbus TCP with CLI and Home Assistant addon support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/cli.ts",
    "cli": "tsx src/cli/cli.ts",
    "addon": "tsx src/ha-addon/addon.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "modbus-serial": "^8.0.17",
    "mqtt": "^5.10.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
